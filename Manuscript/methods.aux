\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Supplementary --- Dengue: importation intensity by travel stream for the top~20 source countries. Blue = background travel; Orange = WC fans. Background dominates for all countries; the WC fan increment is largest for high-incidence WC-qualified nations (Brazil, Colombia, Ecuador).}}{40}{figure.caption.84}\protected@file@percent }
\newlabel{fig:stream_dengue}{{12}{40}{Supplementary --- Dengue: importation intensity by travel stream for the top~20 source countries. Blue = background travel; Orange = WC fans. Background dominates for all countries; the WC fan increment is largest for high-incidence WC-qualified nations (Brazil, Colombia, Ecuador)}{figure.caption.84}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces WC-fan vs.\ background travel stream decomposition for the top 20 source countries by total importation intensity, for each of the five diseases. \textcolor {orange!80!black}{Orange} = WC fans; \textcolor {blue!70!black}{Blue} = background. Countries with WC teams show a non-zero WC-fan component; non-qualified countries contribute only through background travel.}}{41}{figure.caption.86}\protected@file@percent }
\newlabel{fig:stream_panel}{{13}{41}{WC-fan vs.\ background travel stream decomposition for the top 20 source countries by total importation intensity, for each of the five diseases. \textcolor {orange!80!black}{Orange} = WC fans; \textcolor {blue!70!black}{Blue} = background. Countries with WC teams show a non-zero WC-fan component; non-qualified countries contribute only through background travel}{figure.caption.86}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Dengue importation matrix: expected importations $\lambda _{c,v}$ by source country (rows, ordered by total burden) and destination city (columns). Colour scale is the Plasma palette; darker = higher expected importations. Schedule-driven model.}}{42}{figure.caption.88}\protected@file@percent }
\newlabel{fig:heatmap_dengue}{{14}{42}{Dengue importation matrix: expected importations $\lambda _{c,v}$ by source country (rows, ordered by total burden) and destination city (columns). Colour scale is the Plasma palette; darker = higher expected importations. Schedule-driven model}{figure.caption.88}{}}

\newlabel{fig:heatmap_malaria}{{15}{43}{Malaria importation matrix. Same structure as Figure~\ref {fig:heatmap_dengue}. Risk is concentrated in West and Central African source countries}{figure.caption.89}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Measles importation matrix. Low absolute intensities across all cells reflect the low travel-while-infectious probability ($p = 0.05$).}}{44}{figure.caption.90}\protected@file@percent }
\newlabel{fig:heatmap_measles}{{16}{44}{Measles importation matrix. Low absolute intensities across all cells reflect the low travel-while-infectious probability ($p = 0.05$)}{figure.caption.90}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Pertussis importation matrix. The broad geographic spread reflects pertussis's global endemicity and high travel-while-infectious probability ($p = 0.70$).}}{45}{figure.caption.91}\protected@file@percent }
\newlabel{fig:heatmap_pertussis}{{17}{45}{Pertussis importation matrix. The broad geographic spread reflects pertussis's global endemicity and high travel-while-infectious probability ($p = 0.70$)}{figure.caption.91}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Sensitivity analysis: absolute importation intensity $\Lambda _{v,d}$ under $\times $0.50, $\times $0.75, $\times $1.00, $\times $1.25, and $\times $1.50 perturbations of $\rho _d$ and $p_d$ independently. Schedule-driven model (Model 3).}}{46}{figure.caption.93}\protected@file@percent }
\newlabel{fig:sens_abs}{{18}{46}{Sensitivity analysis: absolute importation intensity $\Lambda _{v,d}$ under $\times $0.50, $\times $0.75, $\times $1.00, $\times $1.25, and $\times $1.50 perturbations of $\rho _d$ and $p_d$ independently. Schedule-driven model (Model 3)}{figure.caption.93}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Relative sensitivity of $P(\geq 1 \text  { importation})$: ratio of perturbed to central probability for each parameter multiplier. Cities with high baseline $\Lambda $ (near-saturated) show ratios close to 1.0 regardless of multiplier; low-$\Lambda $ cities exhibit larger relative shifts, revealing where parameter uncertainty matters most.}}{47}{figure.caption.94}\protected@file@percent }
\newlabel{fig:sens_rel}{{19}{47}{Relative sensitivity of $P(\geq 1 \text { importation})$: ratio of perturbed to central probability for each parameter multiplier. Cities with high baseline $\Lambda $ (near-saturated) show ratios close to 1.0 regardless of multiplier; low-$\Lambda $ cities exhibit larger relative shifts, revealing where parameter uncertainty matters most}{figure.caption.94}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Absolute change in $P(\geq 1)$: $\Delta P = P(\geq 1 \mid \text  {perturbed}) - P(\geq 1 \mid \text  {central})$ for each multiplier level. Peak uncertainty is concentrated in mid-range cities rather than in the highest-risk destinations, which are already near certainty.}}{48}{figure.caption.95}\protected@file@percent }
\newlabel{fig:sens_delta}{{20}{48}{Absolute change in $P(\geq 1)$: $\Delta P = P(\geq 1 \mid \text {perturbed}) - P(\geq 1 \mid \text {central})$ for each multiplier level. Peak uncertainty is concentrated in mid-range cities rather than in the highest-risk destinations, which are already near certainty}{figure.caption.95}{}}

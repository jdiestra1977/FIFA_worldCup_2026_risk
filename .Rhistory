summarise(
mean_all_usa_June = mean(all_arrivals_usa, na.rm = TRUE),
.groups = "drop"
)
# ------------------------------------------------------------
# 13. Mean June arrivals to each city from each region (2023-2025)
# ------------------------------------------------------------
# This is the key travel-volume quantity later used in the importation
# model.
# ------------------------------------------------------------
arrivals_only_june <- definite_data_arrivals %>%
filter(month_number == 6, date_year >= "2023") %>%
group_by(region_origin, destination_city) %>%
summarise(
arrivals_June = mean(all_arrivals, na.rm = TRUE),
.groups = "drop"
)
# Optional plot: June arrivals by city and origin region
arrivals_june_plot <- arrivals_only_june %>%
filter(arrivals_June > 0) %>%
ggplot(aes(x = destination_city, y = arrivals_June, fill = region_origin)) +
geom_col(position = position_dodge()) +
scale_y_log10() +
theme_bw()
print(arrivals_june_plot)
dengue_data_world <- read_xlsx("Data/dengue-global-data-2025-12-10.xlsx")
dengue_data_world_selected <- dengue_data_world %>%
select(date, date_lab, who_region_long, country, cases) %>%
mutate(
country = recode(
country,
"Venezuela (Bolivarian Republic of)" = "Venezuela",
"Bolivia (Plurinational State of)"   = "Bolivia",
"Iran (Islamic Republic of)"         = "Iran",
"United Republic of Tanzania"        = "Tanzania"
)
) %>%
left_join(
correspondence_country_region %>% select(country = Country, new_region),
by = "country"
)
# Optional plot: dengue cases over time by region
# This helps inspect seasonality and whether June is a high-burden month.
dengue_time_plot <- dengue_data_world_selected %>%
select(date, new_region, cases) %>%
mutate(cases = replace_na(cases, 0)) %>%
drop_na() %>%
group_by(date, new_region) %>%
summarise(total_cases = sum(cases), .groups = "drop") %>%
filter(date > as.Date("2018-12-31")) %>%
filter(!new_region %in% c("Canada", "Europe")) %>%
ggplot(aes(x = date, y = total_cases)) +
geom_col() +
theme_bw() +
geom_rect(
data = shade_df,
inherit.aes = FALSE,
aes(xmin = xmin, xmax = xmax, ymin = -Inf, ymax = Inf),
fill = "gray80",
alpha = 0.5
) +
facet_wrap(~new_region, scales = "free_y")
print(dengue_time_plot)
# ------------------------------------------------------------
# 15. Mean dengue burden in June by region
# ------------------------------------------------------------
# For each region:
#   1. sum cases across countries on each date
#   2. keep June observations after 2023
#   3. average June cases across recent years
# ------------------------------------------------------------
mean_dengue_cases_regions_june <- dengue_data_world_selected %>%
filter(month(date) == 6, year(date) > 2023) %>%
drop_na() %>%
select(date, new_region, cases) %>%
group_by(date, new_region) %>%
summarise(cases_region = sum(cases), .groups = "drop") %>%
group_by(new_region) %>%
summarise(
mean_cases_june = mean(cases_region, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(new_region = if_else(new_region == "Middle East", "Mideast", new_region))
# ------------------------------------------------------------
# 16. Optional dengue version using routing proportion to city
# ------------------------------------------------------------
# NOTE:
# This reproduces your earlier idea, but it is less clean conceptually
# because arrivals appear twice.
# I am keeping it here only so you can compare both approaches.
# ------------------------------------------------------------
exp_inf_arrivals_origin_dest_dengue_old <- arrivals_only_june %>%
left_join(mean_arrivals_all_usa_june, by = "region_origin") %>%
left_join(
mean_dengue_cases_regions_june %>% rename(region_origin = new_region),
by = "region_origin"
) %>%
left_join(
population_by_region %>%
mutate(new_region = if_else(new_region == "Middle East", "Mideast", new_region)) %>%
rename(region_origin = new_region),
by = "region_origin"
) %>%
mutate(
pro_arrival_to_airport = arrivals_June / mean_all_usa_June,
exp_inf_arrivals = arrivals_June * mean_cases_june / popu_region,
cases_to_city = mean_cases_june * pro_arrival_to_airport,
ver_esto = arrivals_June * cases_to_city / popu_region
)
importation_intensity_june_old <- exp_inf_arrivals_origin_dest_dengue_old %>%
group_by(destination_city) %>%
summarise(
imp_intensity = sum(ver_esto, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(prob_at_least_one = 1 - exp(-imp_intensity))
importation_intensity_june_old
# 17. Cleaner dengue formula (recommended)
# ------------------------------------------------------------
# Here the logic is:
#
# expected infected arrivals from region r to city h =
#   arrivals_June * current_infection_probability * p_travel_inf
#
# where current_infection_probability is approximated as
#   under_rho * (regional_cases / regional_population)
# ------------------------------------------------------------
under_rho_dengue <- 1
p_travel_inf_dengue <- 1
expected_imports_dengue <- arrivals_only_june %>%
left_join(
mean_dengue_cases_regions_june %>% rename(region_origin = new_region),
by = "region_origin"
) %>%
left_join(
population_by_region %>%
mutate(new_region = if_else(new_region == "Middle East", "Mideast", new_region)) %>%
rename(region_origin = new_region),
by = "region_origin"
) %>%
mutate(
current_inf = under_rho_dengue * (mean_cases_june / popu_region),
expected_c_to_h = arrivals_June * current_inf * p_travel_inf_dengue
)
importation_intensity_dengue <- expected_imports_dengue %>%
group_by(destination_city) %>%
summarise(
imp_intensity = sum(expected_c_to_h, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(prob_at_least_one = 1 - exp(-imp_intensity))
importation_intensity_dengue
# Plot dengue importation intensity
plot_importation <- function(df, title_text) {
ggplot(df, aes(x = reorder(destination_city, -imp_intensity), y = imp_intensity)) +
geom_col(fill = "steelblue") +
geom_text(
aes(label = round(prob_at_least_one, 2)),
vjust = -0.5,
size = 5
) +
labs(
x = "",
y = "Importation intensity",
title = title_text
) +
theme_bw() +
theme(text = element_text(size = 20))
}
dengue_plot <- plot_importation(
importation_intensity_dengue,
"Estimated dengue importation intensity by destination city"
)
print(dengue_plot)
